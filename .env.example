# ---- Sicora Consulting Performance Dashboard — environment variables ----

# REQUIRED for the AI analyst notes / Q&A (kept server-side, never sent to the browser)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ENABLES live data. Same Windsor key as BBZ — it already has Sicora's accounts connected.
# Without it the page runs on the bundled snapshot (still fully interactive, just frozen).
WINDSOR_API_KEY=your-windsor-ai-api-key

# --- Sicora data sources in Windsor (defaults already set in server.js) ---
GA4_ACCOUNT_NAME=Sicora GA4
GA4_ACCOUNT=251028744
GADS_ACCOUNT=470-137-4429
GSC_ACCOUNT=https://sicoraconsulting.com/
GHL_ACCOUNT=h0Iu6JkLutDW09474iZ5

# --- Direct GoHighLevel API (email engagement only; everything else comes from Windsor) ---
# OPTIONAL. The dashboard renders fine without this. NOTE: GHL's API does not reliably expose
# email opens/clicks (see SICORA-BUILD-BRIEF.md §3d/§5); this only attempts an unofficial
# location-level aggregate. Leave blank unless/until that endpoint is available to your token.
GHL_API_KEY=
GHL_LOCATION_ID=h0Iu6JkLutDW09474iZ5

# Optional model override (defaults to claude-sonnet-4-6)
MODEL=claude-sonnet-4-6

# --- Auth (fails closed: a user with no password set simply cannot sign in) ---
# Set a strong password for each login. AUTH_SALT can be any stable random string.
PW_CONOR=
PW_ROBERT=
PW_MAGNUS=
PW_LORRI=
PW_LORRI_GMAIL=
PW_GUS=
PW_JASON=
AUTH_SALT=sicora-dash-v1
